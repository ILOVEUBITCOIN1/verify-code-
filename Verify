<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Access Verification</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            color: #fff;
        }
        
        .container {
            text-align: center;
            padding: 40px;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 20px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(10px);
            box-shadow: 0 25px 50px rgba(0, 0, 0, 0.3);
            max-width: 500px;
            width: 90%;
        }
        
        .icon {
            font-size: 60px;
            margin-bottom: 20px;
        }
        
        h1 {
            font-size: 24px;
            margin-bottom: 10px;
            color: #e94560;
        }
        
        .subtitle {
            color: #a0a0a0;
            margin-bottom: 30px;
            font-size: 14px;
        }
        
        .code-box {
            background: linear-gradient(135deg, #0f3460 0%, #16213e 100%);
            border: 2px solid #e94560;
            border-radius: 15px;
            padding: 30px;
            margin: 20px 0;
            position: relative;
            overflow: hidden;
        }
        
        .code-box::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: linear-gradient(45deg, transparent, rgba(233, 69, 96, 0.1), transparent);
            animation: shine 3s infinite;
        }
        
        @keyframes shine {
            0% { transform: translateX(-100%) rotate(45deg); }
            100% { transform: translateX(100%) rotate(45deg); }
        }
        
        #code {
            font-size: 42px;
            font-weight: bold;
            letter-spacing: 8px;
            color: #fff;
            text-shadow: 0 0 20px rgba(233, 69, 96, 0.5);
            position: relative;
            z-index: 1;
            font-family: 'Courier New', monospace;
        }
        
        .timer {
            margin-top: 15px;
            color: #ff6b6b;
            font-size: 13px;
        }
        
        .info {
            margin-top: 25px;
            padding: 15px;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 10px;
            border-left: 3px solid #e94560;
        }
        
        .info p {
            font-size: 13px;
            color: #b0b0b0;
            line-height: 1.6;
        }
        
        .copy-btn {
            margin-top: 20px;
            padding: 12px 30px;
            background: #e94560;
            color: #fff;
            border: none;
            border-radius: 25px;
            cursor: pointer;
            font-size: 16px;
            transition: all 0.3s;
        }
        
        .copy-btn:hover {
            background: #ff6b6b;
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(233, 69, 96, 0.3);
        }
        
        .footer {
            margin-top: 20px;
            font-size: 11px;
            color: #666;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="icon">🔐</div>
        <h1>Access Verification</h1>
        <p class="subtitle">กรุณานำรหัสด้านล่างไปใส่ในบอท</p>
        
        <div class="code-box">
            <div id="code">LOADING...</div>
            <div class="timer">⏱️ รหัสนี้จะเปลี่ยนเมื่อคุณรีเฟรชหน้าเว็บ</div>
        </div>
        
        <button class="copy-btn" onclick="copyCode()">📋 คัดลอกรหัส</button>
        
        <div class="info">
            <p>⚠️ <strong>คำเตือน:</strong> รหัสนี้สุ่มใหม่ทุกครั้งที่เปิดหน้าเว็บ หากคุณรีเฟรชหน้า รหัสเดิมจะใช้ไม่ได้อีก</p>
        </div>
        
        <div class="footer">
            สร้างเมื่อ: <span id="time"></span>
        </div>
    </div>

    <script>
        // สุ่มรหัส 8 ตัว (ตัวพิมพ์ใหญ่ + ตัวเลข ไม่เอาตัวที่คล้ำกัน เช่น O/0 I/1)
        function generateCode() {
            const chars = 'ABCDEFGHJKLMNPQRSTUVWXYZ23456789';
            let code = '';
            for (let i = 0; i < 8; i++) {
                code += chars.charAt(Math.floor(Math.random() * chars.length));
            }
            return code;
        }
        
        // แสดงรหัส
        const code = generateCode();
        document.getElementById('code').textContent = code;
        
        // แสดงเวลา
        document.getElementById('time').textContent = new Date().toLocaleString('th-TH');
        
        // ฟังก์ชันคัดลอก
        function copyCode() {
            navigator.clipboard.writeText(code).then(() => {
                const btn = document.querySelector('.copy-btn');
                btn.textContent = '✅ คัดลอกแล้ว!';
                setTimeout(() => {
                    btn.textContent = '📋 คัดลอกรหัส';
                }, 2000);
            });
        }
    </script>
</body>
</html>
